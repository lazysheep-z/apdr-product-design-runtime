# 阿里云 Token Plan（任选其一作为 API Key）
TOKEN_PLAN_API_KEY=your-token-plan-api-key

# 协议：openai（默认）| anthropic
TOKEN_PLAN_PROTOCOL=openai

# 套餐专属 Base URL（不填则用下方默认值）
# OpenAI 兼容：
# TOKEN_PLAN_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# Anthropic 兼容：
# TOKEN_PLAN_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/apps/anthropic

# 可选：映射前端模型 ID → Token Plan 实际模型名
# TOKEN_PLAN_MODEL_MAX=qwen3.7-max
# TOKEN_PLAN_MODEL_PLUS=qwen3.6-plus
# TOKEN_PLAN_MODEL_FLASH=qwen3.6-flash

# 兼容旧变量名
# DASHSCOPE_API_KEY=your-token-plan-api-key

PORT=8787
