{
  "baseUrl": "/api",
  "endpoints": {
    "health": { "method": "GET", "path": "/health" },
    "smsSend": { "method": "POST", "path": "/auth/sms/send", "body": { "phone": "string" }, "owner": "迈点短信平台" },
    "smsLogin": { "method": "POST", "path": "/auth/sms/login", "body": { "phone": "string", "code": "string" }, "response": { "token": "string" } },
    "guestTrial": { "method": "GET", "path": "/guest/trial", "headers": ["X-Guest-Id"] },
    "chat": { "method": "POST", "path": "/chat", "body": { "message": "string", "model": "qwen3.7-max|qwen3.6-plus|qwen3.6-flash", "history": "array" } },
    "brands": { "method": "GET", "path": "/brands" },
    "brandRanking": { "method": "GET", "path": "/brands/:name/ranking" }
  },
  "mockServer": "projects/brand-digital-intel/server",
  "start": "cd server && npm install && npm start"
}
